# Telegram API Credentials
# Get these from https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash

# Phone number for login
PHONE_NUMBER=+1234567890

# Optional Configuration
# If GROUP_ID is not provided, the script will prompt you with a list of recent chats
GROUP_ID=

# ID of the message to start downloading after (leave blank to start from the beginning)
STARTING_MESSAGE_ID=

# Where to save the downloaded videos
DESTINATION_FOLDER=./downloads
